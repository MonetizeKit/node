{
  "name": "@monetizekit/node",
  "version": "0.1.0",
  "description": "MonetizeKit Node.js SDK for server-side entitlement checks, customer & subscription management, usage/credits, and webhook signature verification.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MonetizeKit/node.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check-entry": "node scripts/check-package-entry.mjs",
    "smoke": "node scripts/install-smoke.mjs",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "dependencies": {
    "@monetizekit/types": "^0.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.19.11",
    "eslint": "^9.20.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  }
}
